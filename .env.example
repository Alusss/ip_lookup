# IP 查询工具站 - 环境变量示例
# 生产环境请根据实际情况修改此文件，然后重命名为 .env

# === 基础配置 ===
ORG=my-org
DOMAIN=ip.iohow.com
DOMAIN_IP4=ip4.iohow.com
DOMAIN_IP6=ip6.iohow.com

# === 监听配置 ===
LISTEN_ADDR_V4=127.0.0.1
LISTEN_ADDR_V6=::1
PORT_V4=8080
PORT_V6=8081

# === 限流配置 ===
RATE_PER_IP=10          # 单 IP 限流（req/min）
RATE_PER_IP_BURST=5
RATE_GLOBAL=1000        # 全局限流 rate (req/s)
RATE_GLOBAL_BURST=1000  # 全局限流 burst

# === API 广告配置（直接访问 ip4/ip6 API 时返回） ===
API_AD_ENABLED=true
API_AD_TEXT_ZH=推荐使用可靠的VPN服务保护您的隐私
API_AD_URL_ZH=https://example.com/zh/vpn
API_AD_TEXT_EN=Recommended VPN service for privacy
API_AD_URL_EN=https://example.com/en/vpn

# === Web 广告配置（前端页面顶栏展示） ===
WEB_AD_ENABLED=true
WEB_AD_TEXT_ZH=推荐使用可靠的VPN服务保护您的隐私
WEB_AD_URL_ZH=https://example.com/zh/vpn
WEB_AD_TEXT_EN=Recommended VPN service for privacy
WEB_AD_URL_EN=https://example.com/en/vpn

# === 日志配置 ===
LOG_LEVEL=info
LOG_FILE_MAX_SIZE=50     # MB
LOG_FILE_MAX_AGE=30      # days
LOG_FILE_BACKUPS=7

# === 安全配置 ===
CORS_ENABLED=true
JSON_API_ENABLED=true
LOG_IP_MASKING=true      # 日志 IP 脱敏
TRUSTED_PROXY_CIDRS=127.0.0.1/32,::1/128  # 可信代理 CIDR 列表（逗号分隔）。Nginx 部署时必须包含 127.0.0.1/32,::1/128；Caddy 部署可留空（Caddy 通过 trusted_proxies 模块代理）
IP_DENYLIST=             # IP 黑名单（逗号分隔），默认空
UA_DENYLIST=             # UA 黑名单子串（逗号分隔），默认空

# === 超时配置 ===
SHUTDOWN_TIMEOUT=15      # 优雅退出超时（秒）
MAX_HEADER_BYTES=1024    # bytes
READ_HEADER_TIMEOUT=5    # seconds
READ_TIMEOUT=10          # seconds
WRITE_TIMEOUT=10         # seconds
IDLE_TIMEOUT=60          # seconds
MAX_CONNS_PER_IP=8

# === 可观测性 ===
METRICS_LISTEN_ADDR=127.0.0.1:9090
PROMETHEUS_PORT=9090

# === 自监控告警（默认关闭，调试阶段保持关闭，后续自行开启） ===
MONITORING_ENABLED=false
MONITORING_WEBHOOK_URL=https://your-webhook-gateway/alert
MONITORING_WEBHOOK_TYPE=generic    # generic 或 dingtalk

# === Cloudflare 配置 ===
# Caddy TLS DNS-01 challenge: set this env var at runtime (systemd EnvironmentFile)
CF_API_TOKEN=your-cloudflare-api-token-here
# CIDR 自动同步 cron（systemd timer 替代）
# CF_CIDR_SYNC_CRON_FULL=0 3 * * *
# CF_CIDR_SYNC_CRON_INCR=0 */6 * * *

# === GeoIP 配置（可选） ===
GEOIP_ENABLED=false
GEOIP_DB_PATH=/var/lib/ip-lookup/GeoLite2-City.mmdb
# MaxMind 许可证密钥（用于 GeoIP 数据库自动更新）
# MAXMIND_LICENSE_KEY=your-maxmind-license-key

# === Docker 配置（可选） ===
DOCKER_IMAGE=ip-lookup:latest

# === Go 版本 ===
GO_VERSION=1.23
BUILD_FLAGS=-trimpath -ldflags="-s -w"
